<mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1650" pageHeight="950" background="#ffffff" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="Recommendation Server Runtime and Behavior" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=left" vertex="1" parent="1"><mxGeometry x="40" y="20" width="780" height="34" as="geometry"/></mxCell><mxCell id="subtitle" value="Spacious source-inspected map: Express bootstrap, recommendation routes, controller/use cases, repositories, engines, cache, offline artifacts, scheduler, and fallback behavior." style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#555555;align=left" vertex="1" parent="1"><mxGeometry x="42" y="56" width="1180" height="24" as="geometry"/></mxCell><mxCell id="server" value="&lt;b&gt;Server boot&lt;/b&gt;&lt;br&gt;src/main.ts&lt;br&gt;Express, CORS, JSON body parsing&lt;br&gt;initDatabase() before listen&lt;br&gt;starts WS gateway and recommendation scheduler" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4d90a4;fontSize=11;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="40" y="105" width="210" height="115" as="geometry"/></mxCell><mxCell id="routes" value="&lt;b&gt;Mounted recommendation API&lt;/b&gt;&lt;br&gt;/api/v1/recommendations&lt;br&gt;GET /status public&lt;br&gt;POST /track auth&lt;br&gt;GET /similar/:productId public&lt;br&gt;GET /:userId auth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=11;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="320" y="105" width="230" height="125" as="geometry"/></mxCell><mxCell id="controller" value="&lt;b&gt;RecommendationController&lt;/b&gt;&lt;br&gt;Parses params and query&lt;br&gt;Validates IDs and strategy&lt;br&gt;Rejects cross-user access&lt;br&gt;Returns AppResponse DTO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="620" y="105" width="230" height="125" as="geometry"/></mxCell><mxCell id="usecase" value="&lt;b&gt;GetRecommendationsUseCase&lt;/b&gt;&lt;br&gt;Owns personalized and similar flows&lt;br&gt;Builds exclusions&lt;br&gt;Checks offline artifact health&lt;br&gt;Runs candidate engines safely&lt;br&gt;Emits decision metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="920" y="105" width="245" height="140" as="geometry"/></mxCell><mxCell id="decision" value="&lt;b&gt;Online decision tree&lt;/b&gt;&lt;br&gt;1. Fresh active offline cache can return immediately.&lt;br&gt;2. Otherwise derive preferences and candidates.&lt;br&gt;3. Run offline model and content engine in parallel.&lt;br&gt;4. Resolve in order: hybrid, offline, content, popularity fallback, hidden.&lt;br&gt;5. Finalize: active products only, de-dupe, limit, diversify homepage first 4 cards." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="1240" y="95" width="310" height="165" as="geometry"/></mxCell><mxCell id="track" value="&lt;b&gt;Track behavior path&lt;/b&gt;&lt;br&gt;Auth user wins over body userId&lt;br&gt;Allowed events: view, add_to_cart, purchase, review, wishlist, search&lt;br&gt;Creates or reuses active UserSession&lt;br&gt;Writes a behavior log row" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#8c8c8c;fontSize=11;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="320" y="330" width="260" height="135" as="geometry"/></mxCell><mxCell id="status" value="&lt;b&gt;Status path&lt;/b&gt;&lt;br&gt;/status inspects model JSON and cache summary&lt;br&gt;Reports configured vs effective engine&lt;br&gt;Shows rollback, cache counts, behavior totals&lt;br&gt;Separates impressions from user-initiated views" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff0f5;strokeColor=#b85450;fontSize=11;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="1240" y="330" width="310" height="135" as="geometry"/></mxCell><mxCell id="behavior" value="&lt;b&gt;user_behavior_logs&lt;/b&gt;&lt;br&gt;Used for training, preferences, exclusions, and popularity&lt;br&gt;Impression views are filtered out&lt;br&gt;Preferences: recent 90 days&lt;br&gt;Popular candidates: recent 30 days" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;spacing=8" vertex="1" parent="1"><mxGeometry x="40" y="360" width="220" height="120" as="geometry"/></mxCell><mxCell id="products" value="&lt;b&gt;products + reviews&lt;/b&gt;&lt;br&gt;Only active and not deleted&lt;br&gt;Feature fields: category, brand, price, avg rating, review count&lt;br&gt;Fallback products sort by featured then newest" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;spacing=8" vertex="1" parent="1"><mxGeometry x="650" y="360" width="230" height="120" as="geometry"/></mxCell><mxCell id="cache" value="&lt;b&gt;recommendation_cache&lt;/b&gt;&lt;br&gt;Serving repo reads personalized rows&lt;br&gt;cache_key: user:type:personalized:algo&lt;br&gt;Freshness checks generated_at and expires_at&lt;br&gt;Online generated cache TTL: 1 hour" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;spacing=8" vertex="1" parent="1"><mxGeometry x="945" y="360" width="235" height="120" as="geometry"/></mxCell><mxCell id="artifact" value="&lt;b&gt;offline artifacts&lt;/b&gt;&lt;br&gt;exports/recommendation-baseline-model.json&lt;br&gt;recommendationsByUser and similarItemsByProduct&lt;br&gt;cache summary records coverage and TTL&lt;br&gt;Health: healthy, stale, missing, invalid" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;spacing=8" vertex="1" parent="1"><mxGeometry x="1240" y="535" width="310" height="125" as="geometry"/></mxCell><mxCell id="engines" value="&lt;b&gt;Candidate engines&lt;/b&gt;&lt;br&gt;&lt;b&gt;OfflineModelRecommendationEngine&lt;/b&gt; reads the JSON model, normalizes score to 0..1, and exposes artifact freshness for serving guards.&lt;br&gt;&lt;b&gt;ContentBasedEngine&lt;/b&gt; scores products from user preferences and product feature similarity.&lt;br&gt;Safe wrappers convert empty or failing engines into explicit fallback reasons instead of failing the request." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="650" y="535" width="530" height="125" as="geometry"/></mxCell><mxCell id="rules" value="&lt;b&gt;Eligibility and scoring behavior&lt;/b&gt;&lt;br&gt;Exclusions: request-specified IDs, purchases, cart additions, wishlist items, and products viewed repeatedly in recent history.&lt;br&gt;Content score: category .40 + brand .20 + price range .20 + rating .20.&lt;br&gt;Similar score: category .45 + brand .20 + price .20 + rating .10 + reviews .05.&lt;br&gt;Popularity fallback score: rating .55 + reviews .25 + purchases .20. If everything is empty, the module is hidden." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=10;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="40" y="535" width="540" height="125" as="geometry"/></mxCell><mxCell id="scheduler" value="&lt;b&gt;Scheduler&lt;/b&gt;&lt;br&gt;Disabled by default&lt;br&gt;Optional runOnStart&lt;br&gt;Skips overlapping runs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=10;align=left;spacing=6" vertex="1" parent="1"><mxGeometry x="40" y="745" width="190" height="90" as="geometry"/></mxCell><mxCell id="export" value="&lt;b&gt;1. Export dataset&lt;/b&gt;&lt;br&gt;Default lookback: 180 days&lt;br&gt;Weights: view/click 1, review 2, cart 3, wishlist 4, purchase 6&lt;br&gt;Output: recommendation-training-data.csv" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=10;align=left;spacing=6" vertex="1" parent="1"><mxGeometry x="300" y="745" width="235" height="100" as="geometry"/></mxCell><mxCell id="train" value="&lt;b&gt;2. Train baseline&lt;/b&gt;&lt;br&gt;Builds item-item cosine similarity&lt;br&gt;Stores topK similar items per product&lt;br&gt;Builds topN unseen recommendations per user&lt;br&gt;Output: recommendation-baseline-model.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=10;align=left;spacing=6" vertex="1" parent="1"><mxGeometry x="610" y="745" width="250" height="110" as="geometry"/></mxCell><mxCell id="precompute" value="&lt;b&gt;3. Precompute cache&lt;/b&gt;&lt;br&gt;Deactivates old rows for user + algorithm&lt;br&gt;Upserts active offline_model personalized rows&lt;br&gt;Writes recommendation-cache-summary.json with coverage metrics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=10;align=left;spacing=6" vertex="1" parent="1"><mxGeometry x="935" y="745" width="245" height="110" as="geometry"/></mxCell><mxCell id="config" value="&lt;b&gt;Config knobs&lt;/b&gt;&lt;br&gt;RECOMMENDATION_ENGINE=offline_model or content_based&lt;br&gt;RECOMMENDATION_MODEL_PATH and SUMMARY_PATH&lt;br&gt;RECOMMENDATION_ENGINE_FORCE_CONTENT_FALLBACK&lt;br&gt;Pipeline interval, lookback, topK, topN, TTL, algorithm" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacing=6" vertex="1" parent="1"><mxGeometry x="1240" y="745" width="310" height="110" as="geometry"/></mxCell><mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;exitX=1;exitY=0.45;entryX=0;entryY=0.45" edge="1" source="server" target="routes" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;exitX=1;exitY=0.45;entryX=0;entryY=0.45" edge="1" source="routes" target="controller" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" value="personalized or similar" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;fontSize=10;exitX=1;exitY=0.4;entryX=0;entryY=0.4" edge="1" source="controller" target="usecase" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e7" value="resolve" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;fontSize=10;exitX=1;exitY=0.45;entryX=0;entryY=0.35" edge="1" source="usecase" target="decision" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" value="track" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;fontSize=10;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" source="routes" target="track" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e5" value="write" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;fontSize=10;exitX=0;exitY=0.55;entryX=1;entryY=0.35" edge="1" source="track" target="behavior" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e6" value="status" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;fontSize=10;exitX=1;exitY=0.75;entryX=0;entryY=0.3" edge="1" source="controller" target="status" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e8" value="preferences / history / popularity" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;fontSize=10;exitX=1;exitY=0.45;entryX=0;entryY=0.55" edge="1" source="behavior" target="decision" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e9" value="features + validation" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;fontSize=10;exitX=1;exitY=0.45;entryX=0;entryY=0.68" edge="1" source="products" target="decision" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e10" value="fresh hit / generated save" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;fontSize=10;exitX=1;exitY=0.45;entryX=0;entryY=0.82" edge="1" source="cache" target="decision" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e11" value="artifact health + similar data" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;fontSize=10;exitX=0.5;exitY=0;entryX=0.85;entryY=1" edge="1" source="artifact" target="decision" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e12" value="candidate scores" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;fontSize=10;exitX=0.95;exitY=0;entryX=0.45;entryY=1" edge="1" source="engines" target="decision" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e13" value="reads live features" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;dashed=1;fontSize=10;exitX=0.25;exitY=0;entryX=0.5;entryY=1" edge="1" source="engines" target="products" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e14" value="reads JSON" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;dashed=1;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.55" edge="1" source="engines" target="artifact" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="p1" value="npm refresh" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" source="scheduler" target="export" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="p2" value="CSV" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" source="export" target="train" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="p3" value="model JSON" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" source="train" target="precompute" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="p4" value="writes rows" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;fontSize=10;exitX=0.5;exitY=0;entryX=0.5;entryY=1" edge="1" source="precompute" target="cache" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="p5" value="updates artifact" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;fontSize=10;exitX=1;exitY=0.45;entryX=0.5;entryY=1" edge="1" source="train" target="artifact" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel>