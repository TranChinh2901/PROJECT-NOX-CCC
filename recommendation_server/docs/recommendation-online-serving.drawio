<mxGraphModel dx="1550" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1450" pageHeight="850" background="#ffffff" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="Recommendation System - Online Serving Path" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=left" vertex="1" parent="1"><mxGeometry x="40" y="25" width="760" height="34" as="geometry"/></mxCell><mxCell id="subtitle" value="Request-time flow for homepage recommendations, PDP similar products, behavior tracking, cache use, and fallback decisions." style="text;html=1;strokeColor=none;fillColor=none;fontSize=12;fontColor=#555555;align=left" vertex="1" parent="1"><mxGeometry x="42" y="60" width="1180" height="24" as="geometry"/></mxCell><mxCell id="client" value="&lt;b&gt;Storefront / API Client&lt;/b&gt;&lt;br&gt;Homepage requests personalized products.&lt;br&gt;PDP requests similar products.&lt;br&gt;UI posts behavior events to improve future recommendations." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4d90a4;fontSize=12;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="40" y="120" width="230" height="125" as="geometry"/></mxCell><mxCell id="routes" value="&lt;b&gt;Recommendation Routes&lt;/b&gt;&lt;br&gt;/api/v1/recommendations&lt;br&gt;GET /:userId - auth personalized&lt;br&gt;GET /similar/:productId - public PDP rail&lt;br&gt;POST /track - auth behavior write&lt;br&gt;GET /status - public health" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=12;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="325" y="120" width="250" height="135" as="geometry"/></mxCell><mxCell id="controller" value="&lt;b&gt;RecommendationController&lt;/b&gt;&lt;br&gt;Parses params and query.&lt;br&gt;Validates numeric IDs and strategy.&lt;br&gt;Rejects cross-user personalized access.&lt;br&gt;Returns AppResponse DTO." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="635" y="120" width="245" height="135" as="geometry"/></mxCell><mxCell id="usecase" value="&lt;b&gt;GetRecommendationsUseCase&lt;/b&gt;&lt;br&gt;Coordinates personalized and similar flows.&lt;br&gt;Builds exclusions.&lt;br&gt;Checks offline health.&lt;br&gt;Loads cache and candidate data.&lt;br&gt;Runs engines safely." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="940" y="120" width="230" height="145" as="geometry"/></mxCell><mxCell id="decision" value="&lt;b&gt;Decision Result&lt;/b&gt;&lt;br&gt;1. Fresh offline cache hit can return immediately.&lt;br&gt;2. Otherwise generate candidates.&lt;br&gt;3. Prefer hybrid when offline and content both work.&lt;br&gt;4. Else use offline, content, popularity fallback, or hide the module.&lt;br&gt;Response includes source, branch, fallbackReason, hidden." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="1220" y="115" width="205" height="210" as="geometry"/></mxCell><mxCell id="track" value="&lt;b&gt;TrackUserBehaviorUseCase&lt;/b&gt;&lt;br&gt;Auth user overrides body userId.&lt;br&gt;Allowed events: view, add_to_cart, purchase, review, wishlist, search.&lt;br&gt;Creates or reuses active UserSession.&lt;br&gt;Writes user_behavior_logs." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#8c8c8c;fontSize=12;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="325" y="335" width="250" height="145" as="geometry"/></mxCell><mxCell id="behavior" value="&lt;b&gt;user_behavior_logs&lt;/b&gt;&lt;br&gt;Used for exclusions, preference derivation, popularity, and offline training.&lt;br&gt;Impression views are ignored.&lt;br&gt;Preference window: 90 days.&lt;br&gt;Popularity window: 30 days." style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;spacing=8" vertex="1" parent="1"><mxGeometry x="40" y="540" width="255" height="125" as="geometry"/></mxCell><mxCell id="products" value="&lt;b&gt;products + reviews&lt;/b&gt;&lt;br&gt;Only active, non-deleted products are eligible.&lt;br&gt;Features: category, brand, price, avg rating, review count.&lt;br&gt;Used by content scoring and final validation." style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;spacing=8" vertex="1" parent="1"><mxGeometry x="365" y="540" width="255" height="125" as="geometry"/></mxCell><mxCell id="cache" value="&lt;b&gt;recommendation_cache&lt;/b&gt;&lt;br&gt;Personalized rows keyed by user + type + algorithm.&lt;br&gt;Freshness checks generated_at and expires_at.&lt;br&gt;Online generated lists are saved for 1 hour." style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;spacing=8" vertex="1" parent="1"><mxGeometry x="690" y="540" width="255" height="125" as="geometry"/></mxCell><mxCell id="artifact" value="&lt;b&gt;offline model artifact&lt;/b&gt;&lt;br&gt;recommendation-baseline-model.json&lt;br&gt;Contains recommendationsByUser and similarItemsByProduct.&lt;br&gt;Health: healthy, stale, missing, invalid." style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;spacing=8" vertex="1" parent="1"><mxGeometry x="1015" y="540" width="255" height="125" as="geometry"/></mxCell><mxCell id="notes" value="&lt;b&gt;Scoring and finalization&lt;/b&gt;&lt;br&gt;Exclusions: explicit request IDs, purchases, cart additions, wishlist items, and repeated recent views.&lt;br&gt;Content score = category .40 + brand .20 + price range .20 + rating .20. Similar score = category .45 + brand .20 + price .20 + rating .10 + reviews .05.&lt;br&gt;Popularity fallback score = rating .55 + reviews .25 + purchases .20. Homepage finalization de-dupes, validates active products, limits count, and diversifies the first 4 cards." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="40" y="710" width="1230" height="85" as="geometry"/></mxCell><mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" source="client" target="routes" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" source="routes" target="controller" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" source="controller" target="usecase" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" source="usecase" target="decision" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" source="routes" target="track" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;exitX=0;exitY=0.5;entryX=0.5;entryY=0" edge="1" source="track" target="behavior" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel>