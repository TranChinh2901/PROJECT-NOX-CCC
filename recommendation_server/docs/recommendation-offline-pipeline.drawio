<mxGraphModel dx="1500" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="850" background="#ffffff" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="Recommendation System - Offline Pipeline and Operations" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=left" vertex="1" parent="1"><mxGeometry x="40" y="25" width="820" height="34" as="geometry"/></mxCell><mxCell id="subtitle" value="Batch refresh flow that converts behavior logs into model artifacts, precomputed cache rows, and status/rollback signals." style="text;html=1;strokeColor=none;fillColor=none;fontSize=12;fontColor=#555555;align=left" vertex="1" parent="1"><mxGeometry x="42" y="60" width="1180" height="24" as="geometry"/></mxCell><mxCell id="scheduler" value="&lt;b&gt;RecommendationRefreshScheduler&lt;/b&gt;&lt;br&gt;Created during server boot from loadedEnv.recommendation.&lt;br&gt;Runs only when schedulerEnabled is true.&lt;br&gt;Supports runOnStart and interval refresh.&lt;br&gt;Skips overlapping runs." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e6;strokeColor=#d6b656;fontSize=12;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="40" y="120" width="260" height="140" as="geometry"/></mxCell><mxCell id="refresh" value="&lt;b&gt;refresh-recommendation-pipeline.ts&lt;/b&gt;&lt;br&gt;Spawned as npm run refresh:recommendation-pipeline.&lt;br&gt;Passes days, topK, topN, ttlHours, and algorithm flags.&lt;br&gt;Runs three pipeline scripts sequentially." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=12;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="370" y="120" width="305" height="140" as="geometry"/></mxCell><mxCell id="status" value="&lt;b&gt;/api/v1/recommendations/status&lt;/b&gt;&lt;br&gt;Reads artifact health, cache summary, active/stale cache counts, latest cache entry, and behavior log totals.&lt;br&gt;Returns configuredMode, effectiveMode, readiness, rollback, coverage, cache, and scheduler settings." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff0f5;strokeColor=#b85450;fontSize=12;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="745" y="120" width="330" height="155" as="geometry"/></mxCell><mxCell id="health" value="&lt;b&gt;Artifact health / rollback&lt;/b&gt;&lt;br&gt;Checks model path, parseability, generatedAt or file mtime, freshness window, and coverage counts.&lt;br&gt;State: healthy, stale, missing, invalid.&lt;br&gt;Degraded artifact or FORCE_CONTENT_FALLBACK makes content_based the effective engine." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="1115" y="120" width="245" height="155" as="geometry"/></mxCell><mxCell id="export" value="&lt;b&gt;1. Export dataset&lt;/b&gt;&lt;br&gt;export-recommendation-dataset.ts&lt;br&gt;Reads user_behavior_logs joined to products.&lt;br&gt;Default lookback: 180 days.&lt;br&gt;Ignores impression-only views.&lt;br&gt;Aggregates one row per user/product.&lt;br&gt;Output: training CSV." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="40" y="350" width="285" height="165" as="geometry"/></mxCell><mxCell id="train" value="&lt;b&gt;2. Train baseline&lt;/b&gt;&lt;br&gt;train-recommendation-baseline.ts&lt;br&gt;Loads CSV interactions.&lt;br&gt;Builds item vectors from weighted user interactions.&lt;br&gt;Computes item-item cosine similarity.&lt;br&gt;Generates topK similar items and topN unseen products per user.&lt;br&gt;Output: model JSON." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="390" y="340" width="330" height="185" as="geometry"/></mxCell><mxCell id="precompute" value="&lt;b&gt;3. Precompute cache&lt;/b&gt;&lt;br&gt;precompute-recommendation-cache.ts&lt;br&gt;Loads recommendation-baseline-model.json.&lt;br&gt;Deactivates old personalized rows for affected users and algorithm.&lt;br&gt;Upserts active offline_model cache entries.&lt;br&gt;Writes cache summary coverage metrics." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="785" y="340" width="330" height="185" as="geometry"/></mxCell><mxCell id="source" value="&lt;b&gt;Source: user_behavior_logs&lt;/b&gt;&lt;br&gt;Weighted actions used in dataset export:&lt;br&gt;view/click = 1&lt;br&gt;review = 2&lt;br&gt;add_to_cart = 3&lt;br&gt;wishlist_add = 4&lt;br&gt;purchase = 6" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;spacing=8" vertex="1" parent="1"><mxGeometry x="40" y="585" width="255" height="125" as="geometry"/></mxCell><mxCell id="model" value="&lt;b&gt;Output: recommendation-baseline-model.json&lt;/b&gt;&lt;br&gt;metadata.generatedAt&lt;br&gt;userCount / itemCount&lt;br&gt;topNRecommendations / topKSimilarItems&lt;br&gt;recommendationsByUser&lt;br&gt;similarItemsByProduct" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;spacing=8" vertex="1" parent="1"><mxGeometry x="440" y="585" width="265" height="125" as="geometry"/></mxCell><mxCell id="cache" value="&lt;b&gt;Output: recommendation_cache&lt;/b&gt;&lt;br&gt;cache_key: user:type:personalized:algo&lt;br&gt;recommended_products JSON&lt;br&gt;context_data includes model metadata&lt;br&gt;generated_at / expires_at&lt;br&gt;is_active=true for current rows" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;spacing=8" vertex="1" parent="1"><mxGeometry x="830" y="585" width="280" height="125" as="geometry"/></mxCell><mxCell id="summary" value="&lt;b&gt;Output: recommendation-cache-summary.json&lt;/b&gt;&lt;br&gt;generatedAt, algorithm, ttlHours&lt;br&gt;insertedEntries&lt;br&gt;userCoverageRatio&lt;br&gt;similarItemCoverageRatio&lt;br&gt;productsWithSimilarItems" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;spacing=8" vertex="1" parent="1"><mxGeometry x="1160" y="585" width="200" height="125" as="geometry"/></mxCell><mxCell id="config" value="&lt;b&gt;Configuration knobs&lt;/b&gt;&lt;br&gt;RECOMMENDATION_PIPELINE_SCHEDULER_ENABLED, RUN_ON_START, REFRESH_INTERVAL_MINUTES, LOOKBACK_DAYS, TOP_K, TOP_N, TTL_HOURS, ALGORITHM. Artifact/status paths: RECOMMENDATION_MODEL_PATH, RECOMMENDATION_CACHE_SUMMARY_PATH. Rollback: RECOMMENDATION_ENGINE_FORCE_CONTENT_FALLBACK." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=11;align=left;spacing=8" vertex="1" parent="1"><mxGeometry x="40" y="755" width="1320" height="55" as="geometry"/></mxCell><mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" source="scheduler" target="refresh" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" source="scheduler" target="export" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" source="export" target="train" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" source="train" target="precompute" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5" edge="1" source="health" target="status" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel>