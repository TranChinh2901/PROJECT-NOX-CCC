    <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="0" y="0" width="1600" height="1050" as="geometry"/></mxCell>
    <mxCell id="title" value="Recommendation System Flow" style="text;html=1;strokeColor=none;fillColor=none;fontSize=26;fontStyle=1;align=left;" vertex="1" parent="1"><mxGeometry x="30" y="20" width="760" height="42" as="geometry"/></mxCell>
    <mxCell id="subtitle" value="Backend serving path, offline refresh path, data stores, and fallback behavior for recommendations." style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#555555;align=left;" vertex="1" parent="1"><mxGeometry x="32" y="58" width="1040" height="26" as="geometry"/></mxCell>

    <mxCell id="online_lane" value="Online Request Serving" style="swimlane;startSize=34;fillColor=#eef6ff;strokeColor=#6c8ebf;html=1;fontStyle=1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="30" y="95" width="1540" height="520" as="geometry"/></mxCell>
    <mxCell id="pipeline_lane" value="Offline Refresh Pipeline" style="swimlane;startSize=34;fillColor=#fff8e6;strokeColor=#d6b656;html=1;fontStyle=1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="30" y="650" width="950" height="330" as="geometry"/></mxCell>
    <mxCell id="ops_lane" value="Status, Config, Observability" style="swimlane;startSize=34;fillColor=#fff0f5;strokeColor=#b85450;html=1;fontStyle=1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1010" y="650" width="560" height="330" as="geometry"/></mxCell>

    <mxCell id="api" value="API routes&lt;br&gt;&lt;b&gt;GET /:userId&lt;/b&gt; personalized&lt;br&gt;&lt;b&gt;GET /similar/:productId&lt;/b&gt; similar&lt;br&gt;&lt;b&gt;POST /track&lt;/b&gt; behavior event&lt;br&gt;&lt;b&gt;GET /status&lt;/b&gt; health" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=13;spacing=10;align=left;" vertex="1" parent="1"><mxGeometry x="65" y="165" width="210" height="150" as="geometry"/></mxCell>
    <mxCell id="controller" value="RecommendationController&lt;br&gt;validates params, strategy, auth&lt;br&gt;rejects cross-user access&lt;br&gt;delegates to use cases" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=13;spacing=10;" vertex="1" parent="1"><mxGeometry x="330" y="165" width="235" height="125" as="geometry"/></mxCell>
    <mxCell id="track" value="TrackUserBehaviorUseCase&lt;br&gt;maps event type&lt;br&gt;writes user_behavior_logs&lt;br&gt;creates/uses active session" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#8c8c8c;fontSize=12;spacing=9;" vertex="1" parent="1"><mxGeometry x="330" y="355" width="235" height="120" as="geometry"/></mxCell>
    <mxCell id="usecase" value="GetRecommendationsUseCase&lt;br&gt;builds exclusion set&lt;br&gt;derives user preferences&lt;br&gt;loads candidate and fallback products" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=13;spacing=10;" vertex="1" parent="1"><mxGeometry x="625" y="165" width="250" height="125" as="geometry"/></mxCell>
    <mxCell id="inputs" value="Serving inputs&lt;br&gt;From behavior logs: exclusions and weighted preferences&lt;br&gt;From products: active candidates, fallback products, ratings&lt;br&gt;Impression-only views are ignored" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#82b366;fontSize=12;spacing=9;align=left;" vertex="1" parent="1"><mxGeometry x="625" y="355" width="250" height="120" as="geometry"/></mxCell>
    <mxCell id="cache_check" value="1. Try fresh offline result&lt;br&gt;Personalized: recommendation_cache&lt;br&gt;Similar: precomputed model artifact&lt;br&gt;Requires healthy/fresh artifact and eligible products" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;spacing=9;" vertex="1" parent="1"><mxGeometry x="930" y="145" width="260" height="120" as="geometry"/></mxCell>
    <mxCell id="engines" value="2. Generate candidates on miss&lt;br&gt;&lt;b&gt;Offline model&lt;/b&gt; reads JSON recommendationsByUser and similarItemsByProduct&lt;br&gt;&lt;b&gt;Content engine&lt;/b&gt; scores category, brand, price, rating, reviews&lt;br&gt;Safe wrappers catch failures and attach fallback reasons" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d79b00;fontSize=12;spacing=9;align=left;" vertex="1" parent="1"><mxGeometry x="930" y="335" width="260" height="150" as="geometry"/></mxCell>
    <mxCell id="resolve" value="3. Resolve decision tree&lt;br&gt;Fresh offline hit&lt;br&gt;Hybrid blend: 60% offline + 40% content&lt;br&gt;Offline only&lt;br&gt;Content only&lt;br&gt;Popularity fallback&lt;br&gt;Hide module when empty" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;spacing=9;align=left;" vertex="1" parent="1"><mxGeometry x="1245" y="145" width="260" height="170" as="geometry"/></mxCell>
    <mxCell id="finalize" value="4. Finalize and respond&lt;br&gt;verify active products&lt;br&gt;de-dupe and limit&lt;br&gt;homepage diversifies first 4 by category/brand&lt;br&gt;cache generated list and log decision trace" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=12;spacing=9;align=left;" vertex="1" parent="1"><mxGeometry x="1245" y="365" width="260" height="140" as="geometry"/></mxCell>

    <mxCell id="db_behavior" value="user_behavior_logs&lt;br&gt;view/click/cart/wishlist/purchase/review&lt;br&gt;used by tracking, preferences, dataset export&lt;br&gt;impression views excluded" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;spacing=8;" vertex="1" parent="1"><mxGeometry x="65" y="475" width="240" height="100" as="geometry"/></mxCell>
    <mxCell id="db_products" value="products + reviews&lt;br&gt;active and not deleted&lt;br&gt;category, brand, price, avg rating&lt;br&gt;used by inputs, content scoring, final validation" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;spacing=8;" vertex="1" parent="1"><mxGeometry x="625" y="500" width="250" height="100" as="geometry"/></mxCell>
    <mxCell id="db_cache" value="recommendation_cache&lt;br&gt;cache_key user:type:algo&lt;br&gt;recommended_products JSON&lt;br&gt;read first, updated after generated results" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;spacing=8;" vertex="1" parent="1"><mxGeometry x="930" y="510" width="260" height="95" as="geometry"/></mxCell>
    <mxCell id="artifacts" value="exports artifacts&lt;br&gt;recommendation-baseline-model.json&lt;br&gt;recommendation-cache-summary.json&lt;br&gt;freshness + coverage checked by status/use case" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;spacing=8;" vertex="1" parent="1"><mxGeometry x="1245" y="520" width="260" height="95" as="geometry"/></mxCell>

    <mxCell id="sched" value="Scheduler&lt;br&gt;optional interval&lt;br&gt;optional runOnStart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;spacing=9;" vertex="1" parent="1"><mxGeometry x="70" y="720" width="150" height="85" as="geometry"/></mxCell>
    <mxCell id="export" value="Export dataset&lt;br&gt;lookback 180d default&lt;br&gt;weighted interactions CSV" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;spacing=9;" vertex="1" parent="1"><mxGeometry x="270" y="720" width="170" height="85" as="geometry"/></mxCell>
    <mxCell id="train" value="Train baseline&lt;br&gt;item-item cosine similarity&lt;br&gt;top-K similar items&lt;br&gt;top-N recommendations/user" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;spacing=9;" vertex="1" parent="1"><mxGeometry x="500" y="710" width="180" height="105" as="geometry"/></mxCell>
    <mxCell id="precompute" value="Precompute cache&lt;br&gt;upsert active offline_model rows&lt;br&gt;write TTL/coverage summary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=12;spacing=9;" vertex="1" parent="1"><mxGeometry x="740" y="720" width="180" height="85" as="geometry"/></mxCell>
    <mxCell id="weights" value="Training weights: view/click=1, review=2, cart=3, wishlist=4, purchase=6&lt;br&gt;Reason text is picked from strongest source signal: purchase, cart, wishlist, or browse." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;spacing=9;" vertex="1" parent="1"><mxGeometry x="120" y="850" width="760" height="70" as="geometry"/></mxCell>

    <mxCell id="status" value="/status response&lt;br&gt;configured vs effective engine&lt;br&gt;artifact readiness and rollback&lt;br&gt;cache row counts&lt;br&gt;behavior log counts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=12;spacing=9;" vertex="1" parent="1"><mxGeometry x="1060" y="715" width="190" height="120" as="geometry"/></mxCell>
    <mxCell id="trace" value="Trace logging&lt;br&gt;surface: homepage or similar&lt;br&gt;source and branch&lt;br&gt;fallback reason&lt;br&gt;cache hit/miss and artifact state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=12;spacing=9;" vertex="1" parent="1"><mxGeometry x="1320" y="715" width="190" height="120" as="geometry"/></mxCell>
    <mxCell id="config" value="Config switches&lt;br&gt;RECOMMENDATION_ENGINE=offline_model/content_based&lt;br&gt;RECOMMENDATION_MODEL_PATH, freshness window, FORCE_CONTENT_FALLBACK&lt;br&gt;scheduler lookback, topK, topN, TTL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=12;spacing=9;" vertex="1" parent="1"><mxGeometry x="1095" y="875" width="380" height="85" as="geometry"/></mxCell>

