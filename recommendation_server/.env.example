# app
PORT=5000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# database
DATABASE_TYPE=mariadb
DB_HOST=....
DB_PORT=....
DB_USERNAME=....
DB_PASSWORD=....
DB_NAME=....

# jwt
JWT_SECRET=....
REFRESH_SECRET=....
ACCESS_EXPIRES_IN=1h
REFRESH_EXPIRES_IN=5d

CLOUD_NAME=....
CLOUD_KEY=....
CLOUD_SECRET=....

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET_PRODUCTS=product-images

# MoMo Sandbox Config
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=
MOMO_REDIRECT_URL=
MOMO_IPN_URL=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gemini Chatbot
GEMINI_API_KEY=
# Optional fallback alias supported by the SDK/server loader.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
# Optional: set when re-embedding the full catalog with a smaller vector size.
GEMINI_EMBEDDING_OUTPUT_DIMENSIONALITY=
# Optional: leave blank for the official Gemini API default. Set only when using a proxy or compatible endpoint.
GEMINI_BASE_URL=
GEMINI_CHATBOT_INSTRUCTIONS=
GEMINI_STOREFRONT_SEARCH_ENABLED=false
GEMINI_STOREFRONT_SEARCH_TIMEOUT_MS=1200
GEMINI_STOREFRONT_SEARCH_MIN_CONFIDENCE=0.7

# Recommendation System
RECOMMENDATION_ENGINE=offline_model
RECOMMENDATION_MODEL_PATH=exports/recommendation-baseline-model.json
RECOMMENDATION_PIPELINE_SCHEDULER_ENABLED=false
RECOMMENDATION_PIPELINE_REFRESH_INTERVAL_MINUTES=360
RECOMMENDATION_PIPELINE_RUN_ON_START=false
RECOMMENDATION_PIPELINE_LOOKBACK_DAYS=180
RECOMMENDATION_PIPELINE_TOP_K=20
RECOMMENDATION_PIPELINE_TOP_N=10
RECOMMENDATION_PIPELINE_TTL_HOURS=24
RECOMMENDATION_PIPELINE_ALGORITHM=offline_model
