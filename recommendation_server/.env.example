# app
PORT=5000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# database
DATABASE_TYPE=mariadb
DB_HOST=....
DB_PORT=....
DB_USERNAME=....
DB_PASSWORD=....
DB_NAME=....

# jwt
JWT_SECRET=....
REFRESH_SECRET=....
ACCESS_EXPIRES_IN=1h
REFRESH_EXPIRES_IN=5d

CLOUD_NAME=....
CLOUD_KEY=....
CLOUD_SECRET=....

# MoMo Sandbox Config
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=
MOMO_REDIRECT_URL=
MOMO_IPN_URL=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Recommended: set this to your GROUP chat id so the bot sends to the group only.
# Group chat ids are usually negative numbers (often start with -100 for supergroups).
# Example:
#   TELEGRAM_GROUP_CHAT_ID=-5215486213
TELEGRAM_GROUP_CHAT_ID=

# Optional: comma-separated list of chat IDs (can include group IDs).
# If set, TELEGRAM_CHAT_IDS will be used instead of TELEGRAM_CHAT_ID.
# Examples:
#   TELEGRAM_CHAT_ID=-5215486213
#   TELEGRAM_CHAT_IDS=-5215486213,1533139965
TELEGRAM_CHAT_IDS=
