# app
PORT=5000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# runtime
# NODE_ENV=development
NODE_ENV=

# logging
# LOG_LEVEL: error|warn|info|debug
LOG_LEVEL=

# Optional: surfaced by the notification module health endpoint.
APP_VERSION=

# database
DATABASE_TYPE=mariadb
DB_HOST=....
DB_PORT=....
DB_USERNAME=....
DB_PASSWORD=....
DB_NAME=....

# Optional: schema drift report script
# Example: SCHEMA_DRIFT_LIMIT=200
SCHEMA_DRIFT_LIMIT=

# jwt
JWT_SECRET=....
REFRESH_SECRET=....
ACCESS_EXPIRES_IN=1h
REFRESH_EXPIRES_IN=5d

CLOUD_NAME=....
CLOUD_KEY=....
CLOUD_SECRET=....

# MoMo Sandbox Config
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=
MOMO_REDIRECT_URL=
MOMO_IPN_URL=

# Client-facing endpoints for notification module tests (optional)
API_BASE_URL=
WS_URL=

# Test database override (optional)
# If set, tests can run against a real DB instead of in-memory sqlite.
TEST_DATABASE_TYPE=
TEST_DB_TYPE=
TEST_DB_HOST=
TEST_DB_PORT=
TEST_DB_USERNAME=
TEST_DB_PASSWORD=
TEST_DB_NAME=

# Chatbot / integrations (optional)
# NOTE: these variables are not referenced by the current server codebase yet.
# Add them here so you have a single place to manage secrets when you wire up the feature.

# SUPABASE
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET_PRODUCTS=

# OpenAI Chatbot
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=
OPENAI_CHATBOT_INSTRUCTIONS=

# Gemini Chatbot
GEMINI_API_KEY=
# Optional fallback alias supported by some SDKs/clients.
GOOGLE_API_KEY=
GEMINI_MODEL=
# Optional: leave blank for the official Gemini API default. Set only when using a proxy or compatible endpoint.
GEMINI_BASE_URL=
GEMINI_CHATBOT_INSTRUCTIONS=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Recommended: set this to your GROUP chat id so the bot sends to the group only.
# Group chat ids are usually negative numbers (often start with -100 for supergroups).
# Example:
#   TELEGRAM_GROUP_CHAT_ID=-5215486213
TELEGRAM_GROUP_CHAT_ID=

# Optional: comma-separated list of chat IDs (can include group IDs).
# If set, TELEGRAM_CHAT_IDS will be used instead of TELEGRAM_CHAT_ID.
# Examples:
#   TELEGRAM_CHAT_ID=-5215486213
#   TELEGRAM_CHAT_IDS=-5215486213,1533139965
TELEGRAM_CHAT_IDS=
